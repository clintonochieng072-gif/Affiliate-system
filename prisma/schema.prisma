generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Affiliate {
  id                         String                    @id @default(uuid())
  email                      String                    @unique
  name                       String?
  createdAt                  DateTime                  @default(now())
  level                      AffiliateLevel            @default(LEVEL_1)
  pendingBalance             Decimal                   @default(0) @db.Decimal(12, 2)
  availableBalance           Decimal                   @default(0) @db.Decimal(12, 2)
  phone                      String?
  totalReferralsIndividual   Int                       @default(0)
  totalReferralsProfessional Int                       @default(0)
  totalEarnings              Decimal                   @default(0) @db.Decimal(12, 2)
  role                       Role                      @default(AFFILIATE)
  isFrozen                   Boolean                   @default(false)
  level4Eligible             Boolean                   @default(false)
  level4EligibleAt           DateTime?
  registrationDate           DateTime                  @default(now())
  updatedAt                  DateTime                  @default(now()) @updatedAt
  promotedAt                 DateTime?                 @db.Timestamptz(6)
  profileCompleted           Boolean                   @default(false)
  totalEarned                Decimal?                  @default(0) @db.Decimal(12, 2)
  links                      AffiliateLink[]
  affiliate_notifications    affiliate_notifications[]
  affiliate_promotions       affiliate_promotions[]
  notifications              Notification[]
  payouts                    Payout[]
  referrals                  Referral[]
  withdrawals                Withdrawal[]

  @@index([email])
  @@index([level])
  @@index([role])
  @@index([email], map: "idx_affiliates_email")
  @@map("affiliates")
}

model Plan {
  id              String           @id @default(uuid())
  planType        String           @unique
  name            String
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  monthlyPrice    Decimal          @db.Decimal(10, 2)
  commissionRules CommissionRule[]
  referrals       Referral[]

  @@index([planType])
  @@index([isActive])
  @@map("plans")
}

model CommissionRule {
  id             String         @id @default(uuid())
  affiliateLevel AffiliateLevel
  planId         String
  rewardAmount   Decimal        @db.Decimal(10, 2)
  createdAt      DateTime       @default(now())
  plan           Plan           @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([affiliateLevel, planId])
  @@index([affiliateLevel])
  @@index([planId])
  @@map("commission_rules")
}

model Product {
  id            String          @id @default(uuid())
  slug          String          @unique
  name          String
  description   String
  url           String
  isHighlighted Boolean         @default(false)
  createdAt     DateTime        @default(now())
  links         AffiliateLink[]

  @@index([slug])
  @@index([isHighlighted])
  @@map("products")
}

model AffiliateLink {
  id           String    @id @default(uuid())
  affiliateId  String
  productSlug  String
  referralCode String    @unique
  createdAt    DateTime  @default(now())
  productId    String
  affiliate    Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([affiliateId, productId])
  @@index([affiliateId])
  @@index([productId])
  @@index([referralCode])
  @@map("affiliate_links")
}

model Referral {
  id                 String         @id @default(uuid())
  affiliateId        String
  commissionAmount   Decimal        @db.Decimal(10, 2)
  status             ReferralStatus @default(pending)
  createdAt          DateTime       @default(now())
  planId             String
  planType           String
  reference          String         @unique
  clientName         String?
  userEmail          String
  referralDate       DateTime       @default(now())
  promotionAppliedAt DateTime?      @db.Timestamptz(6)
  affiliate          Affiliate      @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  plan               Plan           @relation(fields: [planId], references: [id])

  @@index([affiliateId])
  @@index([planId])
  @@index([planType])
  @@index([status])
  @@index([reference])
  @@index([createdAt])
  @@index([userEmail], map: "referrals_clientEmail_idx")
  @@map("referrals")
}

model Payout {
  id          String    @id @default(uuid())
  affiliateId String
  amount      Decimal   @db.Decimal(10, 2)
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([status])
  @@map("payouts")
}

model Withdrawal {
  id                String           @id @default(uuid())
  affiliateId       String
  mpesaNumber       String
  status            WithdrawalStatus @default(pending)
  failureReason     String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  amount            Decimal          @db.Decimal(10, 2)
  providerReference String?          @unique
  completedDate     DateTime?
  completedAt       DateTime?        @db.Timestamptz(6)
  affiliate         Affiliate        @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([status])
  @@index([providerReference])
  @@index([createdAt])
  @@map("withdrawals")
}

model Notification {
  id          String     @id @default(uuid())
  affiliateId String?
  roleTarget  Role
  type        String
  title       String
  message     String
  isRead      Boolean    @default(false)
  createdAt   DateTime   @default(now()) @db.Timestamptz(6)
  affiliate   Affiliate? @relation(fields: [affiliateId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([affiliateId])
  @@index([roleTarget])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model affiliate_notifications {
  id          String    @id
  affiliateId String
  title       String
  message     String
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  affiliates  Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([createdAt])
  @@index([isRead])
}

model affiliate_promotions {
  id          String         @id
  affiliateId String
  fromLevel   AffiliateLevel
  toLevel     AffiliateLevel
  promotedAt  DateTime       @default(now())
  affiliates  Affiliate      @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([promotedAt])
}

enum AffiliateLevel {
  LEVEL_1
  LEVEL_2
  LEVEL_3
  LEVEL_4
}

enum Role {
  AFFILIATE
  ADMIN
}

enum WithdrawalStatus {
  pending
  processing
  completed
  failed
}

enum ReferralStatus {
  active
  pending
}
